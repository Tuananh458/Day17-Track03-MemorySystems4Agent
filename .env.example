# =============================================================================
# Day 17 - Memory Systems for AI Agent
# Sao chép file này thành `.env` rồi điền giá trị thật:
#   copy .env.example .env
# =============================================================================

# --- Model chính (agent trả lời) ---
# Provider: openai | custom | gemini | anthropic | ollama | openrouter
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# --- Model judge (đánh giá chất lượng câu trả lời trong benchmark, tùy chọn) ---
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o-mini
JUDGE_TEMPERATURE=0.0

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Gemini ---
GEMINI_API_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Ollama (local, không cần API key) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenRouter ---
OPENROUTER_API_KEY=

# --- Antco AI Gateway (OpenAI-compatible) ---
# LLM_PROVIDER=antco
# CUSTOM_BASE_URL=https://ai-gateway.antco.ai
# CUSTOM_API_KEY=sk-...
# LLM_MODEL=<model-name-from-dashboard>

# --- Compact memory (tùy chọn, có default trong config.py) ---
COMPACT_THRESHOLD_TOKENS=1200
COMPACT_KEEP_MESSAGES=6

# --- Profile guardrail (bonus) ---
PROFILE_CONFIDENCE_THRESHOLD=0.7

# --- Chế độ chạy ---
# true = không gọi LLM thật, dùng logic offline (đủ cho test/benchmark cơ bản)
FORCE_OFFLINE=false
